                    <script>
                    (function(){
                        var items = [];
                        var currentBarang = null;

                        // Format rupiah
                        function rupiah(n){
                            return 'Rp ' + parseInt(n).toLocaleString('id-ID');
                        }

                        // Update grand total & hidden input
                        function updateGrandTotal(){
                            var total = items.reduce(function(s, i){ return s + i.total; }, 0);
                            document.getElementById('grand_total_display').value = rupiah(total);
                            document.getElementById('grand_total_hidden').value  = total;
                        }

                        // Render tabel
                        function renderTable(){
                            var tbody = document.getElementById('tbodyItems');
                            tbody.innerHTML = '';
                            if(items.length === 0){
                                tbody.innerHTML = '<tr id="emptyRow"><td colspan="8" class="empty-row">Belum ada barang ditambahkan</td></tr>';
                                document.getElementById('btnSelesai').disabled = true;
                                return;
                            }
                            document.getElementById('btnSelesai').disabled = false;
                            items.forEach(function(item, idx){
                                var tr = document.createElement('tr');
                                tr.innerHTML =
                                    '<td>' + item.id + '</td>' +
                                    '<td>' + item.nama + '</td>' +
                                    '<td>' + item.jenis + '</td>' +
                                    '<td>' + item.ukuran + '</td>' +
                                    '<td>' + rupiah(item.harga) + '</td>' +
                                    '<td><input type="number" class="jumlah-input" value="' + item.jumlah + '" min="1" data-idx="' + idx + '"></td>' +
                                    '<td>' + rupiah(item.total) + '</td>' +
                                    '<td><button type="button" class="btn-hapus" data-idx="' + idx + '">Hapus</button></td>';
                                tbody.appendChild(tr);
                            });
                            // Event jumlah
                            tbody.querySelectorAll('.jumlah-input').forEach(function(inp){
                                inp.addEventListener('change', function(){
                                    var i = parseInt(this.dataset.idx);
                                    var jml = parseInt(this.value) || 1;
                                    if(jml < 1) jml = 1;
                                    items[i].jumlah = jml;
                                    items[i].total  = jml * items[i].harga;
                                    document.getElementById('items_json').value = JSON.stringify(items);
                                    updateGrandTotal();
                                    renderTable();
                                });
                            });
                            // Event hapus
                            tbody.querySelectorAll('.btn-hapus').forEach(function(btn){
                                btn.addEventListener('click', function(){
                                    items.splice(parseInt(this.dataset.idx), 1);
                                    document.getElementById('items_json').value = JSON.stringify(items);
                                    updateGrandTotal();
                                    renderTable();
                                });
                            });
                            updateGrandTotal();
                            document.getElementById('items_json').value = JSON.stringify(items);
                        }

                        // Tombol Cari
                        document.getElementById('btnCari').addEventListener('click', function(){
                            var idBarang = document.getElementById('id_barang_cari').value.trim();
                            if(!idBarang){ alert('Masukkan ID barang terlebih dahulu!'); return; }
                            fetch('penjualan.php?ajax_cari=1&id_barang=' + encodeURIComponent(idBarang))
                                .then(function(r){ return r.json(); })
                                .then(function(data){
                                    if(data.error){
                                        alert(data.error);
                                        currentBarang = null;
                                        document.getElementById('nama_barang_display').value = '';
                                        document.getElementById('jenis_display').value = '';
                                        document.getElementById('btnTambah').disabled = true;
                                    } else {
                                        currentBarang = data;
                                        document.getElementById('nama_barang_display').value = data.nama_barang || data.nama || '';
                                        document.getElementById('jenis_display').value        = data.jenis || '';
                                        document.getElementById('btnTambah').disabled = false;
                                    }
                                })
                                .catch(function(){ alert('Gagal menghubungi server!'); });
                        });

                        // Izinkan Enter di field ID barang
                        document.getElementById('id_barang_cari').addEventListener('keydown', function(e){
                            if(e.key === 'Enter'){ e.preventDefault(); document.getElementById('btnCari').click(); }
                        });

                        // Tombol Tambah
                        document.getElementById('btnTambah').addEventListener('click', function(){
                            if(!currentBarang){ alert('Cari barang terlebih dahulu!'); return; }
                            var existing = items.find(function(i){ return i.id == currentBarang.id; });
                            if(existing){
                                existing.jumlah++;
                                existing.total = existing.jumlah * existing.harga;
                            } else {
                                var harga = parseFloat(currentBarang.harga) || 0;
                                items.push({
                                    id     : currentBarang.id,
                                    nama   : currentBarang.nama_barang || currentBarang.nama || '-',
                                    jenis  : currentBarang.jenis || '-',
                                    ukuran : currentBarang.ukuran || '-',
                                    harga  : harga,
                                    jumlah : 1,
                                    total  : harga
                                });
                            }
                            // Reset form cari
                            document.getElementById('id_barang_cari').value  = '';
                            document.getElementById('nama_barang_display').value = '';
                            document.getElementById('jenis_display').value    = '';
                            document.getElementById('btnTambah').disabled     = true;
                            currentBarang = null;
                            renderTable();
                        });

                    })();
                    </script>

